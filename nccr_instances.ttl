nccr-var:ctc-monthsfromdxtobrm a nccr:Variable ;
    rdfs:label "Number of Months from Diagnosis to BRM" ;
    nccr:abbreviatedSourceVocabulary "SEER Recode" ;
    nccr:belongsToSource nccr-ds:ctc ;
    nccr:fieldLength "1-4" ;
