    dct:references nccr-ds:platform .

## ==========================================================
## SUBJECT CONCEPTS
## ==========================================================

nccr-subj:childhood-cancer a skos:Concept ;
    skos:prefLabel "Childhood cancer"@en ;
    skos:definition "Cancers diagnosed in children ages 0-14."@en .

nccr-subj:aya-cancer a skos:Concept ;
    skos:prefLabel "Adolescent and young adult cancer"@en ;
    skos:definition "Cancers diagnosed in adolescents and young adults ages 15-39."@en .

nccr-subj:population-based-registry a skos:Concept ;
    skos:prefLabel "Population-based cancer registry"@en ;
    skos:definition "Systematic collection of cancer data covering a defined geographic population."@en .

nccr-subj:pharmacy-claims a skos:Concept ;
    skos:prefLabel "Pharmacy claims"@en ;
    skos:definition "Data from outpatient pharmacy dispensing records."@en .

nccr-subj:medical-claims a skos:Concept ;
    skos:prefLabel "Medical claims"@en ;
    skos:definition "Data from insurance claims for diagnoses, procedures, and enrollment."@en .

nccr-subj:radiation-oncology a skos:Concept ;
    skos:prefLabel "Radiation oncology"@en ;
    skos:definition "Radiation treatment data from cancer centers and registries."@en .

nccr-subj:area-based-measures a skos:Concept ;
    skos:prefLabel "Area-based measures"@en ;
    skos:definition "Socioeconomic and geographic contextual variables linked to patients via census tracts."@en .

nccr-subj:clinical-trials a skos:Concept ;
    skos:prefLabel "Clinical trials"@en ;
    skos:definition "Data from clinical trial enrollment and registry protocols."@en .

nccr-subj:data-linkage a skos:Concept ;
    skos:prefLabel "Data linkage"@en ;
    skos:definition "Cross-dataset patient matching via participant indices."@en .
