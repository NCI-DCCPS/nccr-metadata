    dct:description "Variable-level data dictionary for the Medical Claims Diagnosis datasource." ;
    dct:references nccr-ds:mcd .

nccr-doc:mce-metadata a datmm:Documentation ;
    dct:title "MCE Data Dictionary" ;
    dct:type "application/json" ;
    dct:identifier "mce_metadata.json" ;
    dct:description "Variable-level data dictionary for the Medical Claims Enrollment datasource." ;
    dct:references nccr-ds:mce .

nccr-doc:mcp-metadata a datmm:Documentation ;
    dct:title "MCP Data Dictionary" ;
    dct:type "application/json" ;
    dct:identifier "mcp_metadata.json" ;
    dct:description "Variable-level data dictionary for the Medical Claims Procedure datasource." ;
    dct:references nccr-ds:mcp .

nccr-doc:pharm-metadata a datmm:Documentation ;
    dct:title "PHARM Data Dictionary" ;
    dct:type "application/json" ;
