    dct:type "application/json" ;
    dct:identifier "ctc_metadata.json" ;
    dct:description "Variable-level data dictionary for the Consolidated Tumor Case datasource. Defines field names, types, permissible values, processing rules, and display settings." ;
    dct:references nccr-ds:ctc .

